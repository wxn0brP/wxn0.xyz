{
	"compilerOptions": {
		"module": "es2022",
		"target": "es2024",
		"moduleResolution": "bundler",
		"paths": {},
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": false,
		"noEmit": true,
		"rootDir": "./src",
		"types": [
			"@wxn0brp/flanker-ui"
		]
	},
	"include": [
		"./src"
	],
	"exclude": [
		"node_modules"
	]
}
